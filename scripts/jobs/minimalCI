#!/usr/bin/env bash
set -euo pipefail

OUT_FILE="security-result.txt"
echo "Security check results" > "$OUT_FILE"

# Minimal illustrative checks:
# 1) No secrets in tracked files (simple grep for typical tokens)
if git ls-files | xargs grep -En --line-number "(API_KEY|SECRET|PASSWORD|token[:=])" >/dev/null 2>&1; then
  echo "FAIL: Possible secret found in repository files" >> "$OUT_FILE"
else
  echo "PASS: No obvious secrets found (simple scan)" >> "$OUT_FILE"
fi

# 2) Ensure .github/workflows doesn't run unpinned actions (basic check)
if grep -R "uses: .*@main" .github/workflows >/dev/null 2>&1; then
  echo "WARN: Some workflows use actions pinned to a branch (e.g., @main). Prefer tags/sha." >> "$OUT_FILE"
else
  echo "PASS: Workflow actions appear pinned (no @main/@master detected)" >> "$OUT_FILE"
fi

cat "$OUT_FILE"
