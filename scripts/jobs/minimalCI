#!/usr/bin/env bash
set -euo pipefail

OUT_FILE="license-result.txt"
echo "License check results" > "$OUT_FILE"

# Simple example: ensure LICENSE file exists and contains "MIT" or "Apache"
if [ ! -f LICENSE ]; then
  echo "FAIL: LICENSE file missing" >> "$OUT_FILE"
  exit 0
fi

if grep -qiE "mit|apache" LICENSE; then
  echo "PASS: LICENSE file present and contains permissive license" >> "$OUT_FILE"
else
  echo "WARN: LICENSE file present but license not recognized (expected MIT/Apache)" >> "$OUT_FILE"
fi

# Print to stdout for logs and keep file for the comment step
cat "$OUT_FILE"
```
