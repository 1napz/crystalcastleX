{
  "name": "@zyntro-media-ai/crystalcastle",
  "version": "1.4.0",
  "description": "Core components for Crystal Castle",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build && tsup src/index.ts --format cjs,esm --dts",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "next": "15.5.18",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "@vercel/analytics": "^1.3.0",
    "@vercel/speed-insights": "^1.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": "20.x"
  }
}
